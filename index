        const video = document.getElementById('video');
        const photoPreview = document.getElementById('photoPreview');
        const canvas = document.getElementById('canvas');
        const shutter = document.getElementById('shutter');
        const retakeBtn = document.getElementById('retakeBtn');
        const submitBtn = document.getElementById('submitBtn');
        const locationText = document.getElementById('locationText');
        const loading = document.getElementById('loading');
        const historyList = document.getElementById('historyList');

        let currentStatus = "Masuk";
        let capturedImage = null;
        let coords = { lat: 0, lng: 0 };

        function handleLogin() {
            const inputNisn = document.getElementById('loginNisn').value;
            const siswa = SISWA_DATABASE.find(s => s.nisn === inputNisn);

            if (siswa) {
                document.getElementById('nisn').value = siswa.nisn;
                document.getElementById('nama').value = siswa.nama;
                document.getElementById('kelas').value = siswa.kelas;
                document.getElementById('loginPage').classList.add('hidden');
                document.getElementById('mainPage').classList.remove('hidden');
                startCamera();
                getLocation();
                loadHistory(siswa.nisn);
            } else {
                alert("NISN tidak ditemukan!");
            }
        }

        function handleLogout() {
            if(confirm("Apakah Anda ingin keluar?")) window.location.reload();
        }

        function setStatus(status) {
            currentStatus = status;
            const btnM = document.getElementById('btnMasuk');
            const btnP = document.getElementById('btnPulang');
            if(status === 'Masuk') {
                btnM.className = "flex-1 py-4 rounded-xl text-xs font-bold flex items-center justify-center gap-2 bg-blue-600 text-white shadow-md transition-all";
                btnP.className = "flex-1 py-4 rounded-xl text-xs font-bold flex items-center justify-center gap-2 text-gray-500 transition-all";
            } else {
                btnP.className = "flex-1 py-4 rounded-xl text-xs font-bold flex items-center justify-center gap-2 bg-blue-600 text-white shadow-md transition-all";
                btnM.className = "flex-1 py-4 rounded-xl text-xs font-bold flex items-center justify-center gap-2 text-gray-500 transition-all";
            }
            validateForm();
        }

        async function startCamera() {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: "user" }, audio: false });
                video.srcObject = stream;
            } catch (e) {
                alert("Izin kamera diperlukan.");
            }
        }

        function takePhoto() {
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            const ctx = canvas.getContext('2d');
            ctx.translate(canvas.width, 0);
            ctx.scale(-1, 1);
            ctx.drawImage(video, 0, 0);
            capturedImage = canvas.toDataURL('image/jpeg', 0.8);
            photoPreview.src = capturedImage;
            video.classList.add('hidden');
            photoPreview.style.display = 'block';
            shutter.classList.add('hidden');
            retakeBtn.classList.remove('hidden');
            validateForm();
        }

        function retakePhoto() {
            capturedImage = null;
            video.classList.remove('hidden');
            photoPreview.style.display = 'none';
            shutter.classList.remove('hidden');
            retakeBtn.classList.add('hidden');
            validateForm();
        }

        function getLocation() {
            locationText.innerText = "Mendeteksi posisi...";
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(
                    (p) => {
                        coords.lat = p.coords.latitude;
                        coords.lng = p.coords.longitude;
                        locationText.innerText = `Terdeteksi: ${coords.lat.toFixed(6)}, ${coords.lng.toFixed(6)}`;
                        locationText.className = "text-xs text-blue-600 font-bold";
                        validateForm();
                    },
                    (e) => { locationText.innerText = "Gagal memuat GPS."; }
                );
            }
        }

        function validateForm() {
            const isReady = capturedImage && coords.lat !== 0;
            if (isReady) {
                submitBtn.disabled = false;
                submitBtn.className = "w-full bg-blue-600 text-white py-4 rounded-2xl font-black text-sm tracking-widest flex items-center justify-center gap-3 shadow-xl active:scale-95 transition-all";
            } else {
                submitBtn.disabled = true;
                submitBtn.className = "w-full bg-gray-200 text-gray-400 py-4 rounded-2xl font-black text-sm tracking-widest flex items-center justify-center gap-3 transition-all";
            }
        }

        function loadHistory(nisn) {
            const history = JSON.parse(localStorage.getItem('absensi_history_' + nisn) || '[]');
            if (history.length > 0) {
                // Menampilkan riwayat dengan detail tanggal dan jam
                historyList.innerHTML = history.reverse().slice(0, 5).map(item => `
                    <div class="flex items-center justify-between p-4 bg-gray-50 rounded-2xl border border-gray-100">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 ${item.status === 'Masuk' ? 'bg-green-100 text-green-600' : 'bg-orange-100 text-orange-600'} rounded-full flex items-center justify-center text-xs">
                                <i class="fa-solid ${item.status === 'Masuk' ? 'fa-sign-in' : 'fa-sign-out'}"></i>
                            </div>
                            <div>
                                <p class="text-xs font-bold text-gray-800">Absen ${item.status}</p>
                                <div class="flex flex-col">
                                    <span class="text-[9px] text-gray-500 font-medium"><i class="fa-regular fa-calendar-check mr-1"></i> ${item.date}</span>
                                    <span class="text-[9px] text-blue-600 font-bold"><i class="fa-regular fa-clock mr-1"></i> ${item.time}</span>
                                </div>
                            </div>
                        </div>
                        <div class="text-[8px] font-mono text-gray-400 bg-white px-2 py-1 rounded-lg shadow-sm border border-gray-100">
                            TERSIMPAN
                        </div>
                    </div>
                `).join('');
            }
        }

        function saveToLocalHistory(data) {
            const nisn = data.nisn;
            const history = JSON.parse(localStorage.getItem('absensi_history_' + nisn) || '[]');
            const now = new Date();
            
            // Format Jam (HH:mm WIB)
            const timeStr = now.getHours().toString().padStart(2, '0') + ':' + 
                            now.getMinutes().toString().padStart(2, '0') + ' WIB';
            
            // Format Tanggal (DD/MM/YYYY)
            const dateStr = now.getDate().toString().padStart(2, '0') + '/' + 
                            (now.getMonth() + 1).toString().padStart(2, '0') + '/' + 
                            now.getFullYear();
            
            history.push({
                status: data.status,
                time: timeStr,
                date: dateStr
            });
            
            localStorage.setItem('absensi_history_' + nisn, JSON.stringify(history));
        }

        async function sendData() {
            loading.style.display = "flex";
            const data = {
                nama: document.getElementById('nama').value,
                nisn: document.getElementById('nisn').value,
                kelas: document.getElementById('kelas').value,
                status: currentStatus,
                lat: coords.lat,
                lng: coords.lng,
                foto: capturedImage
            };
            try {
                await fetch(WEB_APP_URL, { 
                    method: 'POST', 
                    mode: 'no-cors', 
                    cache: 'no-cache',
                    body: JSON.stringify(data) 
                });
                
                saveToLocalHistory(data);
                alert("Absensi " + currentStatus + " Berhasil!");
                window.location.reload();
            } catch (e) {
                alert("Gagal terhubung ke Server.");
            } finally {
                loading.style.display = "none";
            }
        }
    </script>
